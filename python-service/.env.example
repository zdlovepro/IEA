# FastAPI application name
PROJECT_NAME=AI Interactive Lecture API

# Vector database (only needed when enabling Milvus-based retrieval)
MILVUS_URI=http://localhost:19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_DB_NAME=default
COLLECTION_NAME=lecture_knowledge

# Embedding model configuration
EMBEDDING_MODEL_NAME=BAAI/bge-large-zh-v1.5
EMBEDDING_DIM_SIZE=1024

# LLM configuration
# Local minimal integration can leave LLM_API_KEY empty.
LLM_API_KEY=
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=120
