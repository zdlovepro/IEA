# FastAPI application name
PROJECT_NAME=AI Interactive Lecture API

# Vector database (only needed when enabling Milvus-based retrieval)
MILVUS_URI=http://localhost:19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_DB_NAME=default
COLLECTION_NAME=lecture_knowledge

# Embedding model configuration
EMBEDDING_PROVIDER=dashscope
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL_NAME=text-embedding-v4
EMBEDDING_DIM_SIZE=1024
DASHSCOPE_API_KEY=

# LLM configuration
# You can use either the generic LLM_* variables or the DeepSeek-specific aliases.
# Local minimal integration can leave the key empty and fallback logic will be used.
LLM_API_KEY=
LLM_API_BASE=https://api.deepseek.com
LLM_MODEL_NAME=deepseek-v4-pro
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=120
LLM_REASONING_EFFORT=high
LLM_ENABLE_THINKING=true

# Optional DeepSeek aliases (kept empty by default)
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL_NAME=deepseek-v4-pro
DEEPSEEK_REASONING_EFFORT=high
DEEPSEEK_ENABLE_THINKING=true
