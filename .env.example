# Backend runtime profile.
# The backend defaults to `local` when this is omitted.
SPRING_PROFILES_ACTIVE=local

# Shared backend settings.
PYTHON_CLIENT_BASE_URL=http://localhost:8001
TTS_ENABLED=false

# Full mode only: MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=interactive_edu
MYSQL_USERNAME=root
MYSQL_PASSWORD=change-me-mysql-password

# Full mode only: Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=

# Full mode only: MinIO
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=change-me-minio-access-key
MINIO_SECRET_KEY=change-me-minio-secret-key
MINIO_BUCKET=courseware
MINIO_SECURE=false

# Optional: Aliyun TTS, only needed when TTS_ENABLED=true
TTS_ALIYUN_APP_KEY=
TTS_ALIYUN_ACCESS_KEY_ID=
TTS_ALIYUN_ACCESS_KEY_SECRET=
